# Supabase (server only — never expose the service role key to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend email notifications
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Clinic Genie <hello@clinic-genie.com>
CONTACT_NOTIFICATION_EMAIL=hello@clinic-genie.com
